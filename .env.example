# Optional: comma-separated tool names for Claude Code
# CLAUDE_CODE_ALLOWED_TOOLS=Read,Grep,Bash

# Optional: blocked tools
# CLAUDE_CODE_DISALLOWED_TOOLS=Write,Edit

# default | bypassPermissions | plan | acceptEdits | auto | dontAsk
# CLAUDE_CODE_PERMISSION_MODE=default

# Where session metadata and transcripts are stored
# ACP_SESSION_DIR=/home/you/.claude-acp/sessions

# Max concurrent sessions (default 10)
# ACP_MAX_SESSIONS=10

# Executable: npx (default), claude, or absolute path to a .mjs/.js runner script
# CLAUDE_CODE_BIN=npx

# Extra arguments appended after Claude Code flags (space-separated)
# CLAUDE_CODE_EXTRA_ARGS=
